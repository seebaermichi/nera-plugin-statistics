if app.statistics
    .statistics
        each items, category in app.statistics
            if items && items.length > 0
                .statistics__category
                    h3.statistics__title= category.charAt(0).toUpperCase() + category.slice(1)
                    table.statistics__table
                        thead
                            tr
                                th.statistics__header Name
                                th.statistics__header Count
                        tbody
                            each item in items
                                tr.statistics__row
                                    td.statistics__cell= item.name
                                    td.statistics__cell.statistics__cell--count= item.amount
